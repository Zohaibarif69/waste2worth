# Local app
NEXTAUTH_URL=http://localhost:3002
NEXTAUTH_SECRET=replace_with_a_long_random_secret
HACKATHON_SIMPLE_AUTH=true

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Prisma -> Supabase PostgreSQL connection string
# For direct DB host:
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
# For pooler (recommended if IPv6 route issues):
# DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Google Vision API (optional)
GOOGLE_VISION_API_KEY=your_google_vision_key
